    {
      "id": "demo-python-clean-scores",
      "order": 1,
      "type": "code",
      "category": "code",
      "title": "Python 调试示例：过滤有效分数",
      "difficulty": "中等题",
      "difficulty_level": "medium",
      "difficulty_label": "中等题",
      "difficulty_score": 2,
      "difficulty_reason": "需要同时处理 None、负数、0 和顺序保持。",
      "expected_failure_mode": "把 0 当成无效值，或忘记处理 None。",
      "problem_statement": "实现 `clean_scores(scores)`，返回一个新列表，只保留非负整数。\n\n要求：\n- 跳过 `None`\n- 跳过负数\n- 保留 `0`\n- 保持原顺序\n\n你可以点击“运行”查看 public case 的返回值、期望值、stdout 和 traceback。",
      "input_spec": "`scores: list[int | None]`，可能包含 `None`、负数、0 和正数。",
      "output_spec": "`list[int]`，只包含非负整数，顺序与输入一致。",
      "constraints": [
        "不要修改输入列表",
        "保留 0",
        "保持原顺序"
      ],
      "function_signature": "def clean_scores(scores: list) -> list:",
      "function_name": "clean_scores",
      "starter_code": "def clean_scores(scores):\n    print('debug input:', scores)\n    return [x for x in scores if x]\n",
      "solution_code": "def clean_scores(scores):\n    return [x for x in scores if x is not None and x >= 0]\n",
      "supported_runtimes": [
        "python"
      ],
      "default_runtime": "python",
      "examples": [
        {
          "input": {
            "scores": [
              100,
              null,
              -1,
              0,
              88
            ]
          },
          "output": [
            100,
            0,
            88
          ],
          "explanation": "`None` 和 `-1` 被过滤，`0` 必须保留。"
        }
      ],
